NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
# Optional server-side/internal backend URLs for containerized deployment.
API_BASE_URL=http://localhost:8000/api
GRAPHQL_URL=http://localhost:8000/graphql

# Must exactly match the URL you open in the browser during OAuth testing.
# Example redirect URI for Google / LINE:
# http://localhost:3000/api/auth/callback/google
# http://localhost:3000/api/auth/callback/line
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-random-secret
AUTH_SECRET=replace-with-a-random-secret

# Required for Google Maps integration
GOOGLE_MAPS_API_KEY=replace-with-your-google-maps-api-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace-with-your-google-maps-api-key

# Required for "Sign in with Google" (see docs/authentication.md)
GOOGLE_CLIENT_ID=replace-with-your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-your-google-oauth-client-secret

# Required for "Sign in with LINE" (see docs/authentication.md)
LINE_CLIENT_ID=replace-with-your-line-oauth-client-id
LINE_CLIENT_SECRET=replace-with-your-line-oauth-client-secret
