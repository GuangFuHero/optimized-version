# Low-sensitivity staging settings, appended verbatim to the generated .env by deploy.sh.
# Secrets (SECRET_KEY / POSTGRES_PASSWORD / SMTP2GO_API_KEY) come from GCP Secret Manager — never here.
ENV=staging
EMAIL_PROVIDER=smtp2go
EMAIL_FROM=no-reply@wan-guard.com
EMAIL_FROM_NAME=島嶼守望
GOOGLE_CLIENT_ID=717563375943-pibc1j3tdeb6oq4tn7hp3tt78otlgrsj.apps.googleusercontent.com
LINE_CHANNEL_ID=2010287145
APP_BASE_URL=https://demo.wan-guard.com
PHONE_DEFAULT_REGION=TW

# --- Frontend (Next.js) — non-secret config (secrets come from Secret Manager via gen_env) ---
NEXTAUTH_URL=https://demo.wan-guard.com
# Frontend → backend over the internal docker network (never the public URL).
API_BASE_URL=http://backend:8000/api
GRAPHQL_URL=http://backend:8000/graphql
# LINE client id for the frontend's NextAuth provider (same value as LINE_CHANNEL_ID above).
LINE_CLIENT_ID=2010287145
